# Copy file này thành terraform.tfvars và điền thông tin của bạn
# cp terraform.tfvars.example terraform.tfvars

aws_region      = "ap-southeast-1"
sns_topic_name  = "cpu-alert-topic"
alert_email     = "your-email@example.com"   # <-- thay bằng email của bạn
ec2_instance_id = "i-0xxxxxxxxxxxxxxxx"       # <-- thay bằng Instance ID của bạn
cpu_threshold   = 80
period_seconds  = 300
evaluation_periods = 1
